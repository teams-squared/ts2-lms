generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COURSE_MANAGER
  EMPLOYEE
}

model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  name                    String?
  passwordHash            String?
  role                    Role                  @default(EMPLOYEE)
  avatar                  String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  onboardedAt             DateTime?
  invitedAt               DateTime?
  invitedById             String?
  invitedBy               User?                 @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers            User[]                @relation("UserInvites")
  createdCourses          Course[]              @relation("CreatedCourses")
  managedCourses          Course[]              @relation("CourseManagers")
  enrollments             Enrollment[]
  enrollmentsMade         Enrollment[]          @relation("EnrolledBy")
  lessonProgress          LessonProgress[]
  quizAttempts            QuizAttempt[]
  notifications           Notification[]
  achievements            UserAchievement[]
  stats                   UserStats?
  clearances              UserClearance[]
  deadlineReminderLogs    DeadlineReminderLog[]
  policyDocSyncs          PolicyDocLesson[]     @relation("PolicyDocSyncs")
  publicIsoDocSyncs       PublicIsoDoc[]        @relation("PublicIsoDocSyncs")
  publicIsoDocsPublished  PublicIsoDoc[]        @relation("PublicIsoDocsPublished")
  manualRemindersReceived ManualReminderLog[]   @relation("ManualReminderTarget")
  manualRemindersSent     ManualReminderLog[]   @relation("ManualReminderSender")
  isoLibraryViews         IsoLibraryView[]
  internalDocsAuthored    InternalDoc[]         @relation("InternalDocsAuthored")
  internalDocViews        InternalDocView[]
  auditLogs               AuditLog[]            @relation("AuditLogActor")
  assessmentSubmissions   AssessmentSubmission[]
  assessmentsGraded       AssessmentSubmission[] @relation("AssessmentGrader")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model CourseNode {
  id          String       @id @default(cuid())
  name        String
  description String?
  order       Int          @default(0)
  parentId    String?
  parent      CourseNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children    CourseNode[] @relation("NodeHierarchy")
  courses     Course[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Course {
  id                    String                         @id @default(cuid())
  title                 String
  description           String?
  thumbnail             String?
  status                CourseStatus                   @default(DRAFT)
  category              String?
  nodeId                String?
  createdById           String
  node                  CourseNode?                    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  createdBy             User                           @relation("CreatedCourses", fields: [createdById], references: [id])
  managers              User[]                         @relation("CourseManagers")
  modules               Module[]
  enrollments           Enrollment[]
  prerequisites         CoursePrerequisite[]           @relation("CoursePrereqs")
  prerequisiteOf        CoursePrerequisite[]           @relation("PrereqOf")
  clearanceRequirements ResourceClearanceRequirement[]
  emailSubscriptions    CourseEmailSubscription[]
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
}

model CourseEmailSubscription {
  id        String   @id @default(cuid())
  courseId  String
  email     String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, email])
}

enum LessonType {
  TEXT
  VIDEO
  QUIZ
  DOCUMENT
  HTML
  POLICY_DOC
  LINK
  ASSESSMENT
}

enum AssessmentQuestionType {
  MULTIPLE_CHOICE
  FREE_TEXT
}

enum AssessmentSubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  MARKED_PASS
  MARKED_FAIL
}

enum PolicyDocRenderMode {
  PARSED
  EMBED
}

model Module {
  id        String   @id @default(cuid())
  title     String
  order     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, order])
}

model Lesson {
  id                   String                @id @default(cuid())
  title                String
  type                 LessonType            @default(TEXT)
  content              String?
  order                Int
  deadlineDays         Int?
  moduleId             String
  module               Module                @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress             LessonProgress[]
  quizQuestions        QuizQuestion[]
  quizAttempts         QuizAttempt[]
  deadlineReminderLogs DeadlineReminderLog[]
  manualReminderLogs   ManualReminderLog[]
  policyDoc            PolicyDocLesson?
  assessment           AssessmentLesson?
  assessmentVariants   AssessmentVariant[]
  assessmentSubmissions AssessmentSubmission[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([moduleId, order])
  @@index([deadlineDays])
}

/// Policy-doc lesson body — one row per Lesson where type === POLICY_DOC.
/// Holds the SharePoint pointer + the rendered snapshot. Re-syncing the
/// lesson updates this row in place; if `sourceVersion` changes, all prior
/// `LessonProgress.acknowledgedAt` values for this lesson are cleared so
/// employees must re-acknowledge the new version.
model PolicyDocLesson {
  id       String @id @default(cuid())
  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // Source pointer (SharePoint)
  sharePointDriveId String
  sharePointItemId  String
  sharePointWebUrl  String

  // Snapshot from last sync
  documentTitle      String
  documentCode       String?
  sourceVersion      String
  sourceETag         String
  sourceLastModified DateTime
  approver           String?
  approvedOn         DateTime?
  lastReviewedOn     DateTime?
  reviewHistory      Json
  revisionHistory    Json

  // Rendered output
  renderMode       PolicyDocRenderMode @default(PARSED)
  renderedHTML     String              @db.Text
  renderedHTMLHash String

  // Sync bookkeeping
  lastSyncedAt   DateTime
  lastSyncedById String
  lastSyncedBy   User     @relation("PolicyDocSyncs", fields: [lastSyncedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentCode])
}

/// Curated SharePoint-backed ISO document exposed in the public library
/// at /policies. Independent of any course or Lesson — visible to any
/// logged-in LMS user regardless of enrollment. No acknowledgement
/// pipeline; this is read-reference, not compliance evidence.
model PublicIsoDoc {
  id String @id @default(cuid())

  // Source pointer (SharePoint)
  sharePointDriveId String
  sharePointItemId  String
  sharePointWebUrl  String

  // Snapshot from last sync — same parser output as PolicyDocLesson, minus
  // renderedHTML/Hash (no audit snapshot since there's no ack obligation).
  documentTitle      String
  documentCode       String?
  sourceVersion      String
  sourceETag         String
  sourceLastModified DateTime
  approver           String?
  approvedOn         DateTime?
  lastReviewedOn     DateTime?
  reviewHistory      Json
  revisionHistory    Json

  // Display
  sortOrder Int     @default(0)
  isHidden  Boolean @default(false)

  // Provenance
  publishedAt   DateTime @default(now())
  publishedById String
  publishedBy   User     @relation("PublicIsoDocsPublished", fields: [publishedById], references: [id], onDelete: Restrict)

  // Sync bookkeeping
  lastSyncedAt   DateTime
  lastSyncedById String
  lastSyncedBy   User     @relation("PublicIsoDocSyncs", fields: [lastSyncedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  views IsoLibraryView[]

  @@unique([sharePointDriveId, sharePointItemId])
  @@index([sortOrder])
  @@index([documentCode])
}

/// Audit row — one per /policies/[id] open. Best-effort, fire-and-forget
/// from the viewer route. Not used for ack evidence — see LessonProgress
/// for that. Gives admins visibility into which public docs get read.
model IsoLibraryView {
  id             String       @id @default(cuid())
  publicIsoDocId String
  publicIsoDoc   PublicIsoDoc @relation(fields: [publicIsoDocId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt       DateTime     @default(now())
  sourceVersion  String?

  @@index([publicIsoDocId, viewedAt])
  @@index([userId, viewedAt])
}

model Enrollment {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  enrolledById String?
  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledBy User?  @relation("EnrolledBy", fields: [enrolledById], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  startedAt   DateTime?
  completedAt DateTime?

  // Audit snapshot — populated only for POLICY_DOC lessons. Captures the
  // exact version + ETag + content hash the user acknowledged, so we can
  // prove what they actually read in an ISO surveillance audit. Cleared
  // on re-sync when sourceVersion changes (forces re-acknowledgement of
  // the new version).
  acknowledgedAt               DateTime?
  acknowledgedVersion          String?
  acknowledgedETag             String?
  acknowledgedHash             String?
  // Stage-2 ISO 27001 evidence hardening: snapshot the exact attestation
  // wording the learner ticked, the focused-tab dwell time observed, and
  // the SharePoint item id of the source DOCX. All nullable; legacy rows
  // keep NULL and are treated as pre-evidence-hardening records.
  acknowledgedAttestationText  String?
  acknowledgedDwellSeconds     Int?
  acknowledgedSharePointItemId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([userId, completedAt])
}

model SharePointCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  data      String
  etag      String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizQuestion {
  id        String       @id @default(cuid())
  lessonId  String
  text      String
  order     Int
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options   QuizOption[]
  answers   QuizAnswer[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([lessonId, order])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean      @default(false)
  order      Int
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    QuizAnswer[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([questionId, order])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  score          Int
  totalQuestions Int
  passed         Boolean
  createdAt      DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson  Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([lessonId])
  @@index([userId])
}

model QuizAnswer {
  id               String @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String

  attempt        QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuizOption   @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)
}

/// Config side-table — one row per Lesson where type === ASSESSMENT. Holds the
/// server-trusted timer + pass threshold. Kept out of Lesson.content JSON
/// because timeLimitMinutes drives a security-relevant deadline.
model AssessmentLesson {
  id               String   @id @default(cuid())
  lessonId         String   @unique
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  timeLimitMinutes Int
  passThreshold    Int // absolute marks needed to pass (vs sum of question maxMarks)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// One interchangeable version of an assessment. A lesson can hold N variants;
/// each carries its own question set but shares the lesson-level time limit +
/// pass threshold (AssessmentLesson). On start, a student is randomly assigned
/// a variant they have not yet faced (falling back to a full-random pick once
/// every variant has been seen).
model AssessmentVariant {
  id        String               @id @default(cuid())
  lessonId  String
  label     String
  order     Int
  lesson    Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions AssessmentQuestion[]
  submissions AssessmentSubmission[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([lessonId, order])
}

model AssessmentQuestion {
  id           String                 @id @default(cuid())
  variantId    String
  text         String
  order        Int
  questionType AssessmentQuestionType
  maxMarks     Int
  variant      AssessmentVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  options      AssessmentOption[]
  answers      AssessmentAnswer[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([variantId, order])
}

model AssessmentOption {
  id         String             @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean            @default(false)
  order      Int
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([questionId, order])
}

model AssessmentSubmission {
  id            String                     @id @default(cuid())
  userId        String
  lessonId      String
  startedAt     DateTime                   @default(now())
  deadlineAt    DateTime
  submittedAt   DateTime?
  autoSubmitted Boolean                    @default(false)
  status        AssessmentSubmissionStatus @default(IN_PROGRESS)
  autoScore     Int                        @default(0)
  manualScore   Int?
  totalScore    Int?
  passThreshold Int // snapshot at submit so later config edits don't change result
  variantId     String?
  gradedById    String?
  gradedAt      DateTime?
  feedback      String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  variant  AssessmentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  gradedBy User?              @relation("AssessmentGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  answers  AssessmentAnswer[]

  @@index([lessonId])
  @@index([userId])
  @@index([status])
  @@index([variantId])
}

model AssessmentAnswer {
  id               String  @id @default(cuid())
  submissionId     String
  questionId       String
  selectedOptionId String?
  responseText     String?
  awardedMarks     Int?

  submission     AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question       AssessmentQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption AssessmentOption?    @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([submissionId, questionId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  courseId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  title       String
  description String
  icon        String            @default("🏆")
  xpReward    Int               @default(0)
  category    String            @default("general")
  threshold   Int               @default(1)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model UserStats {
  id               String    @id @default(cuid())
  userId           String    @unique
  xp               Int       @default(0)
  streak           Int       @default(0)
  lastActivityDate DateTime?
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastActivityDate])
  @@index([xp(sort: Desc)])
}

/// A compartment users and resources are classified against. Managed list
/// (admins curate via /admin/clearance) — NOT free text. Replaces the dead
/// free-text clearance v1.
model Sector {
  id          String  @id @default(cuid())
  key         String  @unique // slug, e.g. "cybersecurity"
  label       String // display, e.g. "Cybersecurity"
  description String?

  grants       UserClearance[]
  requirements ResourceClearanceRequirement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A user's clearance in one sector. `tier` is an open-ended non-negative
/// integer where LOWER = MORE protected (0 = most restricted). A user holds
/// at most one tier per sector; the tier they hold grants access to that tier
/// and every less-protected (higher-numbered) tier in the same sector.
model UserClearance {
  id        String   @id @default(cuid())
  userId    String
  sectorId  String
  tier      Int // >= 0; lower = more protected; 0 = most restricted
  grantedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sector Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([userId, sectorId]) // at most one tier per sector
  @@index([sectorId])
}

/// A sector+tier requirement attached to exactly one resource (a Course OR an
/// InternalDoc — enforced by a CHECK in the migration). A resource may carry
/// several rows; read access is ANY-satisfies (the viewer needs to satisfy any
/// one of them). `tier` is the threshold T_req: a user satisfies it if they
/// hold a grant in this sector with tier <= T_req.
model ResourceClearanceRequirement {
  id            String  @id @default(cuid())
  sectorId      String
  tier          Int
  courseId      String?
  internalDocId String?

  sector      Sector       @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  course      Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  internalDoc InternalDoc? @relation(fields: [internalDocId], references: [id], onDelete: Cascade)

  @@unique([courseId, sectorId])
  @@unique([internalDocId, sectorId])
  @@index([courseId])
  @@index([internalDocId])
  @@index([sectorId])
}

/// A standalone internal-documentation entry. Reuses the Lesson content model
/// (`type` + `content` follow the same conventions as Lesson) and is rendered
/// by the shared LessonViewer. Gated entirely by clearance: must carry >= 1
/// ResourceClearanceRequirement or it is unreachable by non-admins (the read
/// path uses emptyDefault=false and the write path rejects zero-requirement
/// docs). Authoring is clearance-driven, not admin-only.
model InternalDoc {
  id          String     @id @default(cuid())
  title       String
  type        LessonType @default(TEXT)
  content     String?
  category    String? // optional free-text folder / grouping
  sortOrder   Int        @default(0)
  createdById String
  updatedById String?

  createdBy User @relation("InternalDocsAuthored", fields: [createdById], references: [id], onDelete: Restrict)

  clearanceRequirements ResourceClearanceRequirement[]
  views                 InternalDocView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

/// Best-effort read audit — one row per /internal-docs/[id] open. Mirrors
/// IsoLibraryView; fire-and-forget from the viewer route.
model InternalDocView {
  id            String      @id @default(cuid())
  internalDocId String
  internalDoc   InternalDoc @relation(fields: [internalDocId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt      DateTime    @default(now())

  @@index([internalDocId, viewedAt])
  @@index([userId, viewedAt])
}

model CoursePrerequisite {
  courseId       String
  prerequisiteId String

  course       Course @relation("CoursePrereqs", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite Course @relation("PrereqOf", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([courseId, prerequisiteId])
}

/// Singleton settings row for ISO acknowledgement email recipients.
/// Configured by admins via /admin/emails. The email is gated on `enabled`
/// AND a non-empty `toEmails`; either makes the email a no-op. The audit
/// snapshot on LessonProgress is written regardless — disabling the email
/// never disables the audit record itself.
model IsoNotificationSettings {
  id        String   @id @default("singleton")
  enabled   Boolean  @default(true)
  toEmails  String[]
  ccEmails  String[]
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/// Singleton template for the user-invite email. Configured by admins via
/// /admin/emails. When `bodyText` is empty (or the row is missing), the
/// system falls back to the built-in default. Body supports placeholders:
///   {{name}}, {{firstName}}, {{inviterName}}, {{courses}}, {{joinLink}}
model InviteEmailTemplate {
  id        String   @id @default("singleton")
  subject   String   @default("You've been added to Teams Squared LMS")
  bodyText  String   @default("")
  ccEmails  String[]
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/// Singleton org-level email signature appended to outbound LMS emails
/// (currently the user-invite email; extensible to others). When `enabled`
/// is false or the row is missing, no signature block is rendered.
///
/// `disclaimer` holds an optional confidentiality / legal fine-print block
/// rendered as small muted text below the contact rows. Empty disables
/// that section.
model EmailSignature {
  id           String   @id @default("singleton")
  enabled      Boolean  @default(true)
  signOff      String   @default("Best regards,")
  name         String   @default("")
  title        String   @default("")
  email        String   @default("")
  phone        String   @default("")
  websiteUrl   String   @default("")
  websiteLabel String   @default("")
  addressLine  String   @default("")
  logoUrl      String   @default("")
  disclaimer   String   @default("")
  updatedAt    DateTime @updatedAt
  updatedBy    String?
}

model DeadlineReminderLog {
  id       String   @id @default(cuid())
  userId   String
  lessonId String
  kind     String // "due_soon_1" | "due_today" | "overdue_1"
  sentAt   DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId, kind])
  @@index([lessonId])
}

/// Audit row for manual overdue reminders sent by course managers / admins
/// from /admin/progress. Unlike DeadlineReminderLog (cron, dedupe-keyed),
/// this table has no unique constraint — managers may re-send.
model ManualReminderLog {
  id       String   @id @default(cuid())
  userId   String
  lessonId String
  sentById String?
  sentAt   DateTime @default(now())
  user     User     @relation("ManualReminderTarget", fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  sentBy   User?    @relation("ManualReminderSender", fields: [sentById], references: [id], onDelete: SetNull)

  @@index([userId, lessonId])
  @@index([sentById])
}

/// Centralised security audit trail (ISO 27001 A.8.15 / A.5.28 evidence).
/// One row per sensitive action: login, role change, user delete, clearance
/// grant/revoke, enrollment create/delete. Written best-effort from each
/// mutation route via writeAuditLog() in src/lib/audit.ts.
///
/// Tamper / retention design:
///  - `actorId` is SetNull (NOT cascade) so deleting the actor never erases
///    their audit history — the row survives with actorId NULL.
///  - `actorEmail` snapshots the actor's email at write time so the trail
///    stays human-readable even after the actor row is gone.
///  - `targetId` is a plain string (no FK): targets are frequently deleted
///    (that IS the audited event) and the log must outlive them.
///  - rows are append-only; no route updates or deletes AuditLog.
model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g. "user.role_changed", "clearance.granted"
  actorId    String? // who performed it; NULL = system/cron or deleted actor
  actorEmail String? // denormalised snapshot — survives actor deletion
  targetType String? // "user" | "course" | "enrollment" | "clearance" | "session"
  targetId   String? // id of the affected entity (no FK — targets get deleted)
  metadata   Json? // action-specific detail (old/new role, sector, tier, ...)
  createdAt  DateTime @default(now())

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}
