# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ts2_lms"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Microsoft Entra ID (optional — credentials login works without these
# when ALLOW_PASSWORD_LOGIN is set; see below)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Password-form login (email + bcrypt). Leave UNSET in production — Entra
# SSO is the only auth path there. Set to "true" on staging / local dev
# so humans + the Playwright e2e suite can sign in without an Entra tenant.
ALLOW_PASSWORD_LOGIN=true

# SharePoint integration (Stage 3.5)
SHAREPOINT_SITE_URL=
SHAREPOINT_ROOT_FOLDER=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Teams Squared LMS <lms-noreply@teamsquared.io>

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_DASHBOARD_EMBED_URL=
