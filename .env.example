# NextAuth v5 — required
AUTH_SECRET=

# Microsoft Entra ID (optional — omit to use demo credential accounts only)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# SharePoint / Microsoft Graph (required for real document fetching)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# PostHog analytics (free tier — https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# PostHog server-side API access (required for the admin Analytics dashboard)
# POSTHOG_API_KEY: PostHog → Settings → Personal API keys → create key with read access
# POSTHOG_PROJECT_ID: numeric ID visible in the PostHog URL (/project/12345/...)
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
